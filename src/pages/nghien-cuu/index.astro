---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

let researchItems = [];
try {
  const allResearch = await getCollection('research');
  researchItems = allResearch.filter(item => !item.data.draft);
} catch (e) {
  console.log("No research items found");
}
---
<BaseLayout title="Nghiên cứu | Trịnh Gia Khiêm" description="Các công trình nghiên cứu và tài liệu học thuật.">
  <div class="container content-wrapper page-section">
    <SectionHeading title="Nghiên cứu & Học thuật" subtitle="Công trình" align="left" />
    
    <div class="research-list">
      {researchItems.length > 0 ? (
        researchItems.map(item => (
          <div class="research-card card">
            <span class="status-tag">{item.data.status}</span>
            <h3 class="research-title">{item.data.title}</h3>
            {item.data.englishTitle && <h4 class="research-subtitle">{item.data.englishTitle}</h4>}
            
            <p class="research-desc">{item.data.description}</p>
            
            <div class="research-meta">
              <span class="research-type">{item.data.researchType}</span>
              <div class="keywords">
                {item.data.keywords.map(kw => (
                  <span class="keyword">{kw}</span>
                ))}
              </div>
            </div>
            
            {/* Nếu có trang chi tiết, có thể thêm link ở đây */}
          </div>
        ))
      ) : (
        <p>Các công trình nghiên cứu đang được cập nhật...</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-section {
    padding: var(--space-12) var(--space-4);
  }
  
  .research-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  
  .research-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  
  .status-tag {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-pink-dark);
    background-color: var(--color-cream-warm);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-3);
  }
  
  .research-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
    color: var(--color-text-main);
  }
  
  .research-subtitle {
    font-size: var(--text-base);
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }
  
  .research-desc {
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
  }
  
  .research-meta {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin-top: auto;
  }
  
  .research-type {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
  }
  
  .keywords {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .keyword {
    font-size: var(--text-xs);
    background-color: var(--color-bg-main);
    padding: 2px 8px;
    border-radius: 4px;
    color: var(--color-text-muted);
  }
  
  @media (max-width: 768px) {
    .research-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }
  }
</style>
