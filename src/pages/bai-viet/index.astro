---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

let posts = [];
try {
  const allPosts = await getCollection('blog');
  posts = allPosts.filter(post => !post.data.draft)
                  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());
} catch (e) {
  console.log("No blog posts found");
}
---
<BaseLayout title="Bài viết | Trịnh Gia Khiêm" description="Các bài viết về tâm lý giáo dục, giảng dạy tiếng Anh và AI trong giáo dục.">
  <div class="container content-wrapper page-section">
    <SectionHeading title="Bài viết" subtitle="Blog" align="left" />
    
    <div class="articles-grid">
      {posts.length > 0 ? (
        posts.map(post => (
          <a href={`/bai-viet/${post.id}`} class="article-card card">
            {post.data.coverImage && (
              <img src={post.data.coverImage} alt={post.data.coverAlt || post.data.title} class="article-image" />
            )}
            <div class="article-content">
              <span class="category-tag">{post.data.category}</span>
              <h3 class="article-title">{post.data.title}</h3>
              <p class="article-desc">{post.data.description}</p>
              <div class="article-meta">
                <time>{new Date(post.data.publishedDate).toLocaleDateString('vi-VN')}</time>
                {post.data.readingTime && <span class="separator">•</span>}
                {post.data.readingTime && <span>{post.data.readingTime}</span>}
              </div>
            </div>
          </a>
        ))
      ) : (
        <p>Hiện chưa có bài viết nào được công bố. Đang cập nhật...</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-section {
    padding: var(--space-12) var(--space-4);
  }
  
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-8);
  }
  
  .article-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    color: inherit;
  }
  
  .article-card:hover {
    color: inherit;
  }
  
  .article-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
  }
  
  .article-content {
    padding: var(--space-6);
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .category-tag {
    align-self: flex-start;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-pink-dark);
    background-color: var(--color-pink-light);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }
  
  .article-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }
  
  .article-desc {
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
    flex: 1;
  }
  
  .article-meta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: auto;
  }
  
  .separator {
    margin: 0 var(--space-1);
  }
</style>
