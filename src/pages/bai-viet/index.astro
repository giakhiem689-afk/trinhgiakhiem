---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

let posts = [];
try {
  const allPosts = await getCollection('blog');
  posts = allPosts
    .filter(post => !post.data.draft)
    .sort((a, b) => {
      const timeA = new Date(a.data.updatedDate || a.data.publishedDate).getTime();
      const timeB = new Date(b.data.updatedDate || b.data.publishedDate).getTime();
      return timeB - timeA;
    });
} catch (e) {
  console.log("No blog posts found");
}
---
<BaseLayout title="Bài viết | Trịnh Gia Khiêm" description="Các bài viết về tâm lý giáo dục, giảng dạy tiếng Anh và AI trong giáo dục.">
  <div class="container content-wrapper page-section">
    <SectionHeading title="Bài viết" subtitle="Blog" align="left" />
    
    <div class="articles-list">
      {posts.length > 0 ? (
        posts.map(post => (
          <a href={`/bai-viet/${post.id}`} class="article-card card">
            {post.data.coverImage && (
              <img src={post.data.coverImage} alt={post.data.coverAlt || post.data.title} class="article-image" />
            )}
            <div class="article-content">
              <div class="article-top-meta">
                <span class="category-tag">{post.data.category}</span>
                <span class="article-date">
                  {new Date(post.data.updatedDate || post.data.publishedDate).toLocaleDateString('vi-VN')}
                </span>
              </div>
              <h3 class="article-title">{post.data.title}</h3>
              <p class="article-desc">{post.data.description}</p>
              <div class="article-meta">
                {post.data.readingTime && <span>📖 {post.data.readingTime}</span>}
                <span class="read-more">Đọc tiếp &rarr;</span>
              </div>
            </div>
          </a>
        ))
      ) : (
        <p>Hiện chưa có bài viết nào được công bố. Đang cập nhật...</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-section {
    padding: var(--space-12) var(--space-4);
  }
  
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 900px;
  }
  
  .article-card {
    display: flex;
    flex-direction: row;
    padding: var(--space-6);
    gap: var(--space-6);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    align-items: flex-start;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background-color: var(--color-bg-card);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  
  .article-card:hover {
    color: inherit;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(232, 169, 184, 0.2);
    border-color: var(--color-pink-main);
  }
  
  .article-image {
    width: 220px;
    height: 140px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    flex-shrink: 0;
  }
  
  .article-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .article-top-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }
  
  .category-tag {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-pink-dark);
    background-color: var(--color-pink-light);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
  
  .article-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  
  .article-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    color: var(--color-text-main);
    line-height: 1.4;
  }
  
  .article-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  
  .article-meta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .read-more {
    color: var(--color-pink-dark);
    font-weight: 600;
  }
  
  @media (max-width: 640px) {
    .article-card {
      flex-direction: column;
    }
    
    .article-image {
      width: 100%;
      height: 180px;
    }
  }
</style>
