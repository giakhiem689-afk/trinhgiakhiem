---
import { profile } from '../data/profile';
---
<section class="hero-section">
  <div class="container hero-container">
    <div class="hero-content">
      <span class="greeting">Xin chào, tôi là</span>
      <h1 class="name">{profile.name}</h1>
      <h2 class="tagline">{profile.tagline}</h2>
      <p class="message">{profile.message}</p>
      
      <div class="hero-actions">
        <a href="/nghien-cuu" class="btn btn-primary">Khám phá nghiên cứu</a>
        <a href="/cv" class="btn btn-secondary">Xem CV</a>
      </div>
    </div>
    
    <div class="hero-image-wrapper">
      <div class="hero-shape"></div>
      <img 
        src="/images/profile/placeholder.jpg" 
        alt={`Chân dung ${profile.name}`} 
        class="hero-image" 
        width="400" 
        height="400" 
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: linear-gradient(135deg, #FFF8FA 0%, #F8DDE5 55%, #FFF3E8 100%);
    padding: var(--space-12) 0;
    overflow: hidden;
  }
  
  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  
  .greeting {
    display: block;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }
  
  .name {
    font-size: var(--text-4xl);
    color: var(--color-pink-dark);
    margin-bottom: var(--space-4);
  }
  
  .tagline {
    font-size: var(--text-xl);
    font-family: var(--font-body);
    font-weight: 500;
    margin-bottom: var(--space-4);
    color: var(--color-text-main);
  }
  
  .message {
    font-size: var(--text-base);
    max-width: 600px;
    margin-bottom: var(--space-6);
  }
  
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  
  .hero-image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .hero-shape {
    position: absolute;
    width: 350px;
    height: 350px;
    background-color: var(--color-pink-main);
    border-radius: 50% 40% 60% 40% / 40% 50% 40% 60%;
    opacity: 0.2;
    z-index: 0;
    animation: shapeMorph 8s ease-in-out infinite alternate;
  }
  
  .hero-image {
    position: relative;
    z-index: 1;
    width: 300px;
    height: 300px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    border: 4px solid var(--color-bg-card);
    box-shadow: var(--shadow-lg);
  }
  
  @keyframes shapeMorph {
    0% { border-radius: 50% 40% 60% 40% / 40% 50% 40% 60%; }
    100% { border-radius: 40% 60% 40% 50% / 60% 40% 50% 40%; }
  }
  
  @media (prefers-reduced-motion: reduce) {
    .hero-shape {
      animation: none;
      border-radius: 50%;
    }
  }
  
  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .message {
      margin: 0 auto var(--space-6);
    }
    
    .hero-actions {
      justify-content: center;
    }
    
    .hero-image-wrapper {
      order: -1;
    }
  }
</style>
