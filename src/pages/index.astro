---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Timeline from '../components/Timeline.astro';
import { profile } from '../data/profile';
import { getCollection } from 'astro:content';

// Lấy dữ liệu an toàn phòng trường hợp chưa có bài viết
let recentPosts = [];
let featuredProjects = [];
let featuredResearch = [];

try {
  const allPosts = await getCollection('blog');
  recentPosts = allPosts.sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()).slice(0, 3);
} catch (e) {
  console.log("No blog posts found yet");
}

try {
  const allProjects = await getCollection('projects');
  featuredProjects = allProjects.filter(p => p.data.featured).slice(0, 3);
} catch (e) {
  console.log("No projects found yet");
}

try {
  const allResearch = await getCollection('research');
  featuredResearch = allResearch.filter(r => r.data.featured).slice(0, 1);
} catch (e) {
  console.log("No research found yet");
}
---

<BaseLayout>
  <Hero />

  <!-- Thông tin xác thực nhanh -->
  <section class="section bg-card verification-section">
    <div class="container">
      <div class="verification-grid">
        {profile.verifications.map((item) => (
          <div class="verification-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ba trụ cột chuyên môn -->
  <section class="section pillars-section">
    <div class="container">
      <SectionHeading title="Lĩnh vực chuyên môn" subtitle="Trụ cột" />
      
      <div class="pillars-grid">
        <div class="card pillar-card pillar-psy">
          <div class="pillar-icon">🧠</div>
          <h3>Tâm lý giáo dục & Hỗ trợ người học</h3>
          <p>Ứng dụng tâm lý học để giải quyết các vấn đề học tập, xây dựng động lực và phương pháp học hiệu quả.</p>
        </div>
        
        <div class="card pillar-card pillar-eng">
          <div class="pillar-icon">📝</div>
          <h3>Giảng dạy tiếng Anh & Phản hồi sửa lỗi</h3>
          <p>Nghiên cứu và thực hành Corrective Feedback trong việc cải thiện kỹ năng viết tiếng Anh học thuật.</p>
        </div>
        
        <div class="card pillar-card pillar-ai">
          <div class="pillar-icon">🤖</div>
          <h3>AI & Công nghệ trong giáo dục</h3>
          <p>Tích hợp công cụ trí tuệ nhân tạo một cách có trách nhiệm nhằm nâng cao trải nghiệm dạy và học.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Hành trình -->
  <section class="section bg-card">
    <div class="container content-wrapper">
      <SectionHeading title="Hành trình học tập & Phát triển" subtitle="Timeline" />
      <Timeline />
    </div>
  </section>

  <!-- Call to action -->
  <section class="section cta-section">
    <div class="container text-center">
      <h2>Sẵn sàng hợp tác?</h2>
      <p class="cta-text">Nếu bạn quan tâm đến hỗ trợ người học, giảng dạy tiếng Anh hoặc AI trong giáo dục, tôi rất vui được trao đổi và hợp tác.</p>
      <a href="/lien-he" class="btn btn-primary">Liên hệ với tôi</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding: var(--space-16) 0;
  }
  
  .bg-card {
    background-color: var(--color-bg-card);
  }
  
  .text-center {
    text-align: center;
  }
  
  /* Verification Grid */
  .verification-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-4);
  }
  
  .verification-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
  }
  
  .check-icon {
    color: var(--color-pink-main);
    flex-shrink: 0;
  }
  
  /* Pillars */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  
  .pillar-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  
  .pillar-icon {
    font-size: 2rem;
    margin-bottom: var(--space-4);
    padding: var(--space-3);
    border-radius: var(--radius-lg);
  }
  
  .pillar-psy .pillar-icon { background-color: var(--color-cream-warm); }
  .pillar-eng .pillar-icon { background-color: var(--color-blue-pastel); }
  .pillar-ai .pillar-icon { background-color: var(--color-lavender-pastel); }
  
  /* CTA */
  .cta-section {
    background-color: var(--color-pink-light);
    color: var(--color-text-main);
  }
  
  .cta-text {
    max-width: 600px;
    margin: 0 auto var(--space-8);
  }
  
  @media (max-width: 768px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
