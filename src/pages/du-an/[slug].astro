---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, status, role, tools, coverImage } = project.data;
---

<BaseLayout title={`${title} | Dự án`} description={description} image={coverImage}>
  <article class="project-container content-wrapper">
    <header class="project-header text-center">
      <div class="mb-4">
        <StatusBadge status={status} />
      </div>
      <h1 class="project-title">{title}</h1>
      
      <div class="project-meta">
        <p><strong>Vai trò:</strong> {role}</p>
        <div class="project-tools mt-4">
          {tools.map((tool: string) => (
            <span class="tool-tag">{tool}</span>
          ))}
        </div>
      </div>
      
      {coverImage && (
        <div class="project-cover mt-8">
          <img src={coverImage} alt={title} class="card" />
        </div>
      )}
    </header>
    
    <div class="project-content">
      <div class="prose">
        <Content />
      </div>
    </div>
    
    <div class="back-link mt-12 text-center">
      <a href="/du-an" class="btn btn-primary">&larr; Quay lại danh sách dự án</a>
    </div>
  </article>
</BaseLayout>

<style>
  .project-container {
    padding: var(--space-12) var(--space-4);
    max-width: 800px;
    margin: 0 auto;
  }
  
  .project-header {
    margin-bottom: var(--space-12);
  }
  
  .mb-4 { margin-bottom: var(--space-4); }
  .mt-4 { margin-top: var(--space-4); }
  .mt-8 { margin-top: var(--space-8); }
  .mt-12 { margin-top: var(--space-12); }
  
  .project-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
    color: var(--color-pink-dark);
  }
  
  .project-meta {
    font-size: var(--text-lg);
    color: var(--color-text-main);
  }
  
  .project-tools {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }
  
  .tool-tag {
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-pink-light);
    color: var(--color-pink-dark);
    border-radius: var(--radius-sm);
    font-weight: 500;
  }
  
  .project-cover img {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }
  
  .prose {
    font-size: var(--text-lg);
    line-height: 1.8;
  }
  
  .prose :global(h2) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    color: var(--color-pink-dark);
  }
  
  .prose :global(h3) {
    margin-top: var(--space-6);
  }
  
  .prose :global(p) {
    margin-bottom: var(--space-6);
  }
  
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }
  
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
  
  .prose :global(a) {
    text-decoration: underline;
    text-decoration-color: var(--color-pink-light);
    text-underline-offset: 4px;
  }
  
  .prose :global(blockquote) {
    border-left: 4px solid var(--color-pink-main);
    padding-left: var(--space-4);
    margin-left: 0;
    font-style: italic;
    color: var(--color-text-muted);
  }
</style>
