---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

let projects = [];
try {
  const allProjects = await getCollection('projects');
  projects = allProjects.filter(p => !p.data.draft);
} catch (e) {
  console.log("No projects found");
}
---
<BaseLayout title="Dự án | Trịnh Gia Khiêm" description="Các dự án giáo dục, hỗ trợ sinh viên và ứng dụng công nghệ.">
  <div class="container content-wrapper page-section">
    <SectionHeading title="Dự án thực tế" subtitle="Kinh nghiệm" align="left" />
    
    <div class="projects-grid">
      {projects.length > 0 ? (
        projects.map(project => (
          <div class="project-card card">
            {project.data.coverImage && (
              <img src={project.data.coverImage} alt={project.data.coverAlt || project.data.title} class="project-image" />
            )}
            <div class="project-content">
              <span class="status-tag">{project.data.status}</span>
              <h3 class="project-title">{project.data.title}</h3>
              <p class="project-role"><strong>Vai trò:</strong> {project.data.role}</p>
              <p class="project-desc">{project.data.description}</p>
              
              <div class="project-tools">
                {project.data.tools.map(tool => (
                  <span class="tool">{tool}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      ) : (
        <p>Danh sách dự án đang được cập nhật...</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-section {
    padding: var(--space-12) var(--space-4);
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-8);
  }
  
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
  }
  
  .project-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
  }
  
  .project-content {
    padding: var(--space-6);
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  
  .status-tag {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-pink-dark);
    background-color: var(--color-sage-pastel);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-3);
  }
  
  .project-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }
  
  .project-role {
    font-size: var(--text-sm);
    color: var(--color-pink-dark);
    margin-bottom: var(--space-2);
  }
  
  .project-desc {
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
    flex: 1;
  }
  
  .project-tools {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }
  
  .tool {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    background-color: var(--color-bg-main);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }
</style>
